.page-bottom-space {
  height: calc(128rpx + env(safe-area-inset-bottom));
}

.divider {
  height: 1px;
  background: rgba(220, 229, 240, 0.92);
}

page {
  min-height: 100%;
  color: #152033;
  background: radial-gradient(circle at 12% 0%, rgba(47, 107, 255, 0.18), transparent 26%), radial-gradient(circle at 86% 8%, rgba(18, 179, 168, 0.14), transparent 22%), linear-gradient(180deg, #fcfdff 0%, #eef4fa 100%);
  font-family: "PingFang SC", "HarmonyOS Sans SC", "Noto Sans SC", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  display: none;
}

.page-shell {
  min-height: 100vh;
  padding: 0 32rpx calc(144rpx + env(safe-area-inset-bottom));
}

.page-shell--tight-bottom {
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}

.page-stack {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.section-stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.surface-card {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.72);
}
.surface-card::before {
  content: "";
  position: absolute;
  inset: 0 0 auto;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(47, 107, 255, 0.38), rgba(18, 179, 168, 0.18), transparent);
  opacity: 0.85;
}
.surface-card::after {
  content: "";
  position: absolute;
  right: -42rpx;
  bottom: -56rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle at center, rgba(47, 107, 255, 0.08), transparent 68%);
  pointer-events: none;
}
.surface-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 250, 255, 0.92));
  box-shadow: 0 20rpx 56rpx rgba(25, 61, 118, 0.12);
}

.panel-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: -0.03em;
}

.panel-copy {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #5c6980;
}