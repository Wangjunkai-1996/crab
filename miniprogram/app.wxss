.motion-fade-in {
  animation: motionFadeIn 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

.motion-slide-up {
  animation: motionSlideUp 240ms cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes motionFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
@keyframes motionSlideUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
.glass-chip {
