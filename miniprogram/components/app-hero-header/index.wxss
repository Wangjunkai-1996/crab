.hero__head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.hero__content {
  display: flex;
  flex: 1;
  gap: 20rpx;
}

.hero__back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.16);
  color: inherit;
  font-size: 40rpx;
  line-height: 1;
}

.hero--surface .hero__back,
.hero--form .hero__back {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(244, 248, 253, 0.92));
  color: #152033;
}

.hero__meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
}

.hero__top-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero__kicker {
  font-size: 24rpx;
  letter-spacing: 0.08em;
  color: rgba(255, 255, 255, 0.78);
}

.hero--surface .hero__kicker,
.hero--form .hero__kicker {
  color: #5c6980;
}

.hero__title {
  font-family: "SF Pro Display", "HarmonyOS Sans SC", "PingFang SC", "Noto Sans SC", sans-serif;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.08;
  letter-spacing: -0.05em;
  color: inherit;
}

.hero__subtitle {
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.8);
}

.hero--surface .hero__subtitle,
.hero--form .hero__subtitle {
  color: #5c6980;
}

.hero__action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: inherit;
  font-size: 24rpx;
}

.hero--surface .hero__action,
.hero--form .hero__action {
  background: rgba(47, 107, 255, 0.1);
  color: #2457e6;
}

.hero__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.hero__badge--accent {
  background: rgba(255, 181, 71, 0.16);
  border: 1px solid rgba(255, 181, 71, 0.24);
  color: #fff;
}

.hero--surface .hero__badge--accent,
.hero--form .hero__badge--accent {
  color: #d77f11;
}

.hero__badge--primary {
  background: rgba(47, 107, 255, 0.12);
  border: 1px solid rgba(47, 107, 255, 0.24);
  color: #2457e6;
}