.bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0.98) 26%);
  border-top: 1px solid rgba(221, 231, 244, 0.94);
  box-shadow: 0 -18rpx 40rpx rgba(14, 31, 60, 0.06);
}

.bar__inner {
  display: flex;
  gap: 20rpx;
}

.bar__button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.bar__button--secondary {
  min-height: 88rpx;
  border-radius: 999rpx;
  color: #152033;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(244, 248, 253, 0.92));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.58);
}

.bar__button--primary {
  min-height: 88rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #1f56e8 0%, #2f6bff 52%, #53b4ff 100%);
  box-shadow: 0 18rpx 36rpx rgba(47, 107, 255, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

.bar__button--disabled {
  min-height: 88rpx;
  border-radius: 999rpx;
  background: rgba(195, 207, 219, 0.72);
  color: rgba(21, 32, 51, 0.46);
}