.empty-card {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.72);
}
.empty-card::before {
  content: "";
  position: absolute;
  inset: 0 0 auto;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(47, 107, 255, 0.38), rgba(18, 179, 168, 0.18), transparent);
  opacity: 0.85;
}
.empty-card::after {
  content: "";
  position: absolute;
  right: -42rpx;
  bottom: -56rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle at center, rgba(47, 107, 255, 0.08), transparent 68%);
  pointer-events: none;
}
.empty-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 250, 255, 0.92));
  box-shadow: 0 20rpx 56rpx rgba(25, 61, 118, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  min-height: 320rpx;
  text-align: center;
}

.empty-illus {
  position: relative;
  width: 92rpx;
  height: 92rpx;
  border-radius: 30rpx;
  background: radial-gradient(circle at 34% 30%, rgba(47, 107, 255, 0.22), transparent 24%), linear-gradient(180deg, rgba(248, 250, 253, 0.98), rgba(255, 255, 255, 0.98));
}

.empty-illus::before,
.empty-illus::after {
  content: "";
  position: absolute;
  border-radius: 18rpx;
}

.empty-illus::before {
  inset: 18rpx 18rpx 36rpx;
  background: linear-gradient(135deg, rgba(47, 107, 255, 0.24), rgba(18, 179, 168, 0.12));
}

.empty-illus::after {
  left: 22rpx;
  right: 22rpx;
  bottom: 16rpx;
  height: 10rpx;
  background: rgba(47, 107, 255, 0.14);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #152033;
}

.empty-description {
  color: #5c6980;
  font-size: 26rpx;
  line-height: 1.6;
}

.empty-action {
  min-width: 220rpx;
  min-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(244, 248, 253, 0.92));
  color: #2457e6;
  font-size: 26rpx;
  line-height: 72rpx;
}