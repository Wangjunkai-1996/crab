.sheet-wrap {
  position: fixed;
  inset: 0;
  z-index: 30;
}

.sheet-wrap__mask {
  position: absolute;
  inset: 0;
  background: rgba(21, 32, 51, 0.42);
}

.sheet-wrap__panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 255, 0.94));
  box-shadow: 0 28rpx 84rpx rgba(16, 38, 78, 0.18);
}

.sheet-wrap__header,
.sheet-wrap__actions {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.sheet-wrap__header {
  align-items: center;
}

.sheet-wrap__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #152033;
}

.sheet-wrap__summary {
  font-size: 24rpx;
  color: #5c6980;
}

.sheet-wrap__group {
  margin-top: 28rpx;
}

.sheet-wrap__group-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #5c6980;
}

.sheet-wrap__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sheet-wrap__placeholder {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 1px solid rgba(214, 224, 238, 0.92);
  background: linear-gradient(180deg, rgba(248, 250, 253, 0.96), rgba(255, 255, 255, 0.84));
}

.sheet-wrap__placeholder-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #152033;
}

.sheet-wrap__placeholder-copy {
  font-size: 24rpx;
  line-height: 1.6;
  color: #5c6980;
}

.segment {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 196rpx;
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  border: 1px solid rgba(214, 224, 238, 0.92);
  background: rgba(255, 255, 255, 0.78);
  color: #152033;
  font-size: 24rpx;
}

.segment--active {
  background: linear-gradient(180deg, rgba(47, 107, 255, 0.12), rgba(255, 255, 255, 0.9));
  border-color: rgba(47, 107, 255, 0.28);
  color: #2457e6;
}

.sheet-wrap__actions {
  margin-top: 32rpx;
}

.sheet-wrap__button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.sheet-wrap__button--secondary {
  min-height: 88rpx;
  border-radius: 999rpx;
  color: #152033;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(244, 248, 253, 0.92));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.58);
}

.sheet-wrap__button--primary {
  min-height: 88rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #1f56e8 0%, #2f6bff 52%, #53b4ff 100%);
  box-shadow: 0 18rpx 36rpx rgba(47, 107, 255, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.2);
}