.form-card {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.72);
}
.form-card::before {
  content: "";
  position: absolute;
  inset: 0 0 auto;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(47, 107, 255, 0.38), rgba(18, 179, 168, 0.18), transparent);
  opacity: 0.85;
}
.form-card::after {
  content: "";
  position: absolute;
  right: -42rpx;
  bottom: -56rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle at center, rgba(47, 107, 255, 0.08), transparent 68%);
  pointer-events: none;
}
.form-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 250, 255, 0.92));
  box-shadow: 0 20rpx 56rpx rgba(25, 61, 118, 0.12);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-card__head,
.form-card__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.form-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #152033;
}

.form-card__badge,
.form-card__required {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.form-card__badge--accent {
  background: rgba(255, 181, 71, 0.16);
  border: 1px solid rgba(255, 181, 71, 0.24);
  color: #d77f11;
}

.form-card__required {
  background: rgba(47, 107, 255, 0.08);
  color: #2457e6;
}

.form-card__list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.form-card__item {
  padding: 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(251, 253, 255, 0.98), rgba(244, 248, 253, 0.96));
  border: 1px solid rgba(216, 226, 239, 0.96);
}

.form-card__item--error {
  border-color: rgba(227, 93, 106, 0.34);
  background: rgba(255, 240, 243, 0.54);
}

.form-card__label,
.form-card__hint {
  color: #5c6980;
  font-size: 24rpx;
}

.form-card__value {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #152033;
}

.form-card__error {
  display: block;
  margin-top: 10rpx;
  color: #e35d6a;
  font-size: 24rpx;
}