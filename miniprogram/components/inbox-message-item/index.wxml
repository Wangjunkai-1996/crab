<view class="message-item" bindtap="onItemTap">
  <view class="message-bubble message-bubble--{{message.messageType}}">
    {{message.messageType === 'review' ? '审' : (message.messageType === 'application' ? '报' : '系')}}
    <text wx:if="{{!message.isRead}}" class="message-bubble__dot"></text>
  </view>
  <view class="message-main">
    <view class="message-main__head">
      <text class="message-title">{{message.title}}</text>
      <text class="message-arrow">›</text>
    </view>
    <view class="message-meta">
      <text class="message-type">{{message.messageType === 'review' ? '审核通知' : (message.messageType === 'application' ? '报名进展' : '系统提醒')}}</text>
      <text class="message-time">{{message.timeText}}</text>
    </view>
    <text class="message-summary">{{message.summary}}</text>
  </view>
</view>
