.message-item {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.72);
}
.message-item::before {
  content: "";
  position: absolute;
  inset: 0 0 auto;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(47, 107, 255, 0.38), rgba(18, 179, 168, 0.18), transparent);
  opacity: 0.85;
}
.message-item::after {
  content: "";
  position: absolute;
  right: -42rpx;
  bottom: -56rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle at center, rgba(47, 107, 255, 0.08), transparent 68%);
  pointer-events: none;
}
.message-item {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 250, 255, 0.92));
  box-shadow: 0 20rpx 56rpx rgba(25, 61, 118, 0.12);
  display: grid;
  grid-template-columns: 88rpx 1fr auto;
  gap: 20rpx;
  align-items: center;
}

.message-bubble {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.message-bubble--review {
  background: linear-gradient(145deg, rgba(47, 107, 255, 0.94), rgba(18, 179, 168, 0.78));
}

.message-bubble--application {
  background: linear-gradient(145deg, rgba(18, 179, 168, 0.92), rgba(94, 207, 200, 0.84));
}

.message-bubble--system {
  background: linear-gradient(145deg, rgba(255, 181, 71, 0.94), rgba(243, 154, 34, 0.84));
}

.message-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.message-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #152033;
}

.message-summary,
.message-time {
  font-size: 24rpx;
  color: #5c6980;
  line-height: 1.6;
}

.message-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.12);
  color: #2457e6;
  font-size: 24rpx;
}