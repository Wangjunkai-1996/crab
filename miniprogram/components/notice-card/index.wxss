.card {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.72);
}
.card::before {
  content: "";
  position: absolute;
  inset: 0 0 auto;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(47, 107, 255, 0.38), rgba(18, 179, 168, 0.18), transparent);
  opacity: 0.85;
}
.card::after {
  content: "";
  position: absolute;
  right: -42rpx;
  bottom: -56rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle at center, rgba(47, 107, 255, 0.08), transparent 68%);
  pointer-events: none;
}
.card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 250, 255, 0.92));
  box-shadow: 0 20rpx 56rpx rgba(25, 61, 118, 0.12);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.card--featured {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 249, 255, 0.96));
  border-color: rgba(223, 232, 244, 0.96);
  box-shadow: 0 26rpx 64rpx rgba(18, 44, 90, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.card__head,
.card__footer,
.card__kv {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.card__head {
  align-items: center;
}

.card__money {
  font-family: "SF Pro Display", "DIN Alternate", "HarmonyOS Sans SC", sans-serif;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.05em;
  color: #d77f11;
  text-align: right;
}

.card__title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.42;
  letter-spacing: -0.03em;
  color: #152033;
}

.card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.card__pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(214, 224, 238, 0.92);
  background: rgba(255, 255, 255, 0.78);
  color: #5c6980;
  font-size: 24rpx;
}

.card__pill--primary {
  background: linear-gradient(180deg, rgba(47, 107, 255, 0.12), rgba(255, 255, 255, 0.9));
  border-color: rgba(47, 107, 255, 0.28);
  color: #2457e6;
}

.card__pill--accent {
  background: rgba(255, 181, 71, 0.16);
  border-color: rgba(255, 181, 71, 0.24);
  color: #d77f11;
}

.card__kv {
  color: #5c6980;
  font-size: 26rpx;
}

.card__kv text:last-child {
  color: #152033;
  font-weight: 600;
}

.card__footer {
  padding-top: 18rpx;
  border-top: 1px solid rgba(220, 229, 240, 0.92);
}

.card__publisher {
  color: #5c6980;
  font-size: 24rpx;
}