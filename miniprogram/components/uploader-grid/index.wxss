.uploader-grid {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.uploader-grid__list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.uploader-grid__item {
  position: relative;
  width: 176rpx;
  height: 176rpx;
  overflow: hidden;
  border-radius: 24rpx;
  border: 1px solid rgba(216, 226, 239, 0.96);
  background: rgba(255, 255, 255, 0.88);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.78), 0 10rpx 22rpx rgba(26, 48, 90, 0.04);
}

.uploader-grid__item--add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(180deg, rgba(47, 107, 255, 0.08), rgba(255, 255, 255, 0.94));
}

.uploader-grid__image {
  width: 100%;
  height: 100%;
}

.uploader-grid__remove {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(21, 32, 51, 0.68);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 1;
}

.uploader-grid__plus {
  color: #2457e6;
  font-size: 44rpx;
  font-weight: 600;
  line-height: 1;
}

.uploader-grid__add-text {
  color: #152033;
  font-size: 24rpx;
}

.uploader-grid__add-count,
.uploader-grid__hint {
  color: #5c6980;
  font-size: 22rpx;
  line-height: 1.5;
}