.app-detail-stack {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.app-detail-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.app-detail-card__status,
.app-detail-card__contact {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(18, 179, 168, 0.12);
  color: #0a766f;
  font-size: 24rpx;
  align-self: flex-start;
}

.app-detail-card__title,
.app-detail-card__section-title,
.timeline-copy__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #152033;
}

.app-detail-card__row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  color: #5c6980;
  font-size: 26rpx;
}

.app-detail-card__row text:last-child {
  color: #152033;
  text-align: right;
}

.app-detail-card__copy,
.timeline-copy__desc {
  color: #5c6980;
  font-size: 26rpx;
  line-height: 1.6;
}

.timeline-item {
  display: flex;
  gap: 16rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #2f6bff;
  margin-top: 12rpx;
  box-shadow: 0 0 0 6rpx rgba(47, 107, 255, 0.12);
}

.timeline-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}