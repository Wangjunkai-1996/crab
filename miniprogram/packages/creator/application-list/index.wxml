<view class="page-shell page-shell--tight-bottom">
  <app-hero-header theme="surface" kicker="我的报名" title="跟进合作进度" subtitle="按状态查看，重点看当前处于哪个阶段、联系方式是否已释放。" showBack="{{true}}" topInset="{{topInset}}"></app-hero-header>
  <view class="surface-card insight-card motion-slide-up">
    <view class="insight-card__head">
      <view>
        <text class="insight-card__eyebrow">报名总览</text>
        <text class="insight-card__title">这里优先解决“我现在在哪个阶段、下一步该回哪里处理”。</text>
      </view>
      <text class="pill-primary">{{activeStatus === 'all' ? '全部状态' : '当前筛选'}}</text>
    </view>
    <view class="guide-grid">
      <view class="guide-card">
        <text class="guide-card__eyebrow">先看什么</text>
        <text class="guide-card__title">先看状态，再判断联系方式是否已经释放</text>
        <text class="guide-card__copy">列表先帮你筛出最值得继续跟进的报名，详情页再承接完整时间线和动作说明。</text>
      </view>
    </view>
    <view wx:if="{{focusCard}}" class="focus-card">
      <view class="focus-card__head">
        <text class="focus-card__title">当前最值得先看的报名</text>
        <text class="pill-accent">{{focusCard.badgeText}}</text>
      </view>
      <text class="focus-card__headline">{{focusCard.title}}</text>
      <text class="focus-card__copy">{{focusCard.copy}}</text>
    </view>
  </view>
  <view class="app-list-stack">
    <page-skeleton wx:if="{{pageState === 'loading'}}"></page-skeleton>
    <page-error-state wx:elif="{{pageState === 'error'}}" title="报名列表加载失败" description="{{errorText}}" actionText="重新加载" bind:action="loadPage"></page-error-state>
    <empty-state wx:elif="{{pageState === 'empty'}}" title="还没有报名记录" description="可以先回广场继续看看新合作，后续状态变化也会统一回到这里查看。" actionText="回合作广场" bind:action="onEmptyAction"></empty-state>
    <block wx:else>
      <stats-summary-card items="{{stats}}"></stats-summary-card>
      <view class="segment-row">
        <view wx:for="{{tabs}}" wx:key="value" class="segment {{activeStatus === item.value ? 'segment--active' : ''}}" data-value="{{item.value}}" bindtap="onSwitchStatus">{{item.label}}</view>
      </view>
      <view wx:if="{{filteredEmpty}}" class="surface-card inline-empty-card">
        <text class="inline-empty-card__title">当前状态下暂无报名</text>
        <text class="inline-empty-card__copy">保留上面的统计和筛选栏，方便你继续切换其它状态快速浏览，不用整页退回重来。</text>
      </view>
      <block wx:else>
        <view wx:for="{{list}}" wx:key="applicationId" class="surface-card app-item" data-id="{{item.applicationId}}" bindtap="onTapItem">
          <view class="app-item__head">
            <status-tag status="{{item.status}}" text="{{item.statusText}}"></status-tag>
            <text class="app-item__time">{{item.updatedAt || item.city}}</text>
          </view>
          <text class="app-item__title">{{item.noticeTitle}}</text>
          <view class="app-item__metrics">
            <text class="app-item__pill app-item__pill--accent">{{item.budgetSummary}}</text>
            <text class="app-item__pill">{{item.publisherSummary.displayName}}</text>
            <text class="app-item__pill">{{item.city}}</text>
          </view>
          <text class="app-item__summary">{{item.nextActionText}}</text>
          <view class="app-item__footer">
            <text class="app-item__contact {{item.canViewPublisherContact ? 'app-item__contact--visible' : ''}}">{{item.contactText}}</text>
            <text class="app-item__cta">查看详情</text>
          </view>
        </view>
      </block>
    </block>
  </view>
</view>
