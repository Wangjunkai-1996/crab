.app-list-stack {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.segment-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.segment {
  flex: 1;
  min-width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  border-radius: 20rpx;
  border: 1px solid rgba(214, 224, 238, 0.92);
  background: rgba(255, 255, 255, 0.78);
  color: #5c6980;
  font-size: 24rpx;
}

.segment--active {
  background: linear-gradient(180deg, rgba(47, 107, 255, 0.12), rgba(255, 255, 255, 0.9));
  color: #2457e6;
  border-color: rgba(47, 107, 255, 0.28);
}

.app-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.app-item__head,
.app-item__row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.app-item__status,
.app-item__contact {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 181, 71, 0.16);
  color: #d77f11;
  font-size: 24rpx;
}

.app-item__contact {
  align-self: flex-start;
  background: rgba(214, 224, 238, 0.36);
  color: #5c6980;
}

.app-item__contact--visible {
  background: rgba(18, 179, 168, 0.12);
  color: #0a766f;
}

.app-item__time {
  color: #5c6980;
  font-size: 24rpx;
}

.app-item__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #152033;
}

.app-item__row {
  font-size: 26rpx;
  color: #5c6980;
}

.app-item__row text:last-child {
  color: #152033;
}