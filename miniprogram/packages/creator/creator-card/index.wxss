.form-stack {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-section__head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #152033;
}

.form-section__copy {
  color: #5c6980;
  font-size: 26rpx;
  line-height: 1.6;
}

.form-section__meta {
  color: #2457e6;
  font-size: 24rpx;
}

.form-summary-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.form-summary-pill,
.option-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(214, 224, 238, 0.92);
  color: #5c6980;
  background: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.form-summary-pill--primary,
.option-chip--active {
  color: #2457e6;
  background: linear-gradient(180deg, rgba(47, 107, 255, 0.12), rgba(255, 255, 255, 0.9));
  border-color: rgba(47, 107, 255, 0.28);
}

.form-summary-pill--accent {
  color: #d77f11;
  background: rgba(255, 181, 71, 0.14);
  border-color: rgba(255, 181, 71, 0.28);
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-field__label-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.form-field__label {
  font-size: 28rpx;
  font-weight: 600;
  color: #152033;
}

.form-field__required {
  color: #e35d6a;
  font-size: 24rpx;
}

.form-field__hint {
  color: #5c6980;
  font-size: 24rpx;
  line-height: 1.6;
}

.form-field__error {
  color: #e35d6a;
  font-size: 24rpx;
}

.form-input,
.form-picker,
.form-textarea {
  width: 100%;
  color: #152033;
  font-size: 28rpx;
}

.form-input,
.form-picker {
  padding: 0 24rpx;
  min-height: 88rpx;
  border-radius: 20rpx;
  border: 1px solid rgba(216, 226, 239, 0.96);
  background: linear-gradient(180deg, rgba(251, 253, 255, 0.98), rgba(244, 248, 253, 0.96));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.78), 0 10rpx 22rpx rgba(26, 48, 90, 0.04);
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-picker__placeholder {
  color: #8a96a8;
}

.form-picker__arrow {
  color: #8a96a8;
}

.form-textarea {
  min-height: 220rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  border: 1px solid rgba(216, 226, 239, 0.96);
  background: linear-gradient(180deg, rgba(251, 253, 255, 0.98), rgba(244, 248, 253, 0.96));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.78), 0 10rpx 22rpx rgba(26, 48, 90, 0.04);
}

.form-input--error,
.form-picker--error,
.form-textarea--error {
  border-color: rgba(227, 93, 106, 0.52);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.78), 0 10rpx 22rpx rgba(227, 93, 106, 0.1);
}

.option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.info-card,
.success-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-card__title,
.success-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #152033;
}

.info-card__copy,
.success-card__copy {
  color: #5c6980;
  font-size: 26rpx;
  line-height: 1.6;
}

.success-card {
  background: linear-gradient(180deg, rgba(234, 251, 248, 0.92), rgba(255, 255, 255, 0.98));
}

.creator-card-stack {
  margin-top: 24rpx;
}

.preview-card {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.preview-card__avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(18, 179, 168, 0.92), rgba(94, 207, 200, 0.84));
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
}

.preview-card__meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
}

.preview-card__name {
  font-size: 30rpx;
  font-weight: 600;
  color: #152033;
}

.preview-card__summary {
  color: #5c6980;
  font-size: 26rpx;
  line-height: 1.6;
}

.preview-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preview-card__tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(214, 224, 238, 0.92);
  color: #5c6980;
  background: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.preview-card__tag--active {
  color: #2457e6;
  background: linear-gradient(180deg, rgba(47, 107, 255, 0.12), rgba(255, 255, 255, 0.9));
  border-color: rgba(47, 107, 255, 0.28);
}