<view class="page-shell">
  <app-hero-header
    theme="surface"
    kicker="意见反馈"
    title="把问题和建议说清楚"
    subtitle="提交成功后会生成反馈编号，后续若需要补充信息会通过消息中心联系你。"
    showBack="{{true}}"
    topInset="{{topInset}}"
  ></app-hero-header>

  <view class="page-stack feedback-stack">
    <view wx:if="{{submitted}}" class="surface-card success-card">
      <text class="success-card__title">反馈已提交</text>
      <text class="success-card__copy">当前编号：{{feedbackId}}。我们会优先处理截图清晰、描述明确的问题反馈；如需补充信息，会通过消息中心联系你。</text>
      <view class="form-summary-row">
        <text wx:for="{{summaryPills}}" wx:key="label" class="form-summary-pill {{item.active ? 'form-summary-pill--primary' : ''}}">{{item.label}}</text>
      </view>
    </view>

    <block wx:else>
      <view class="surface-card form-section">
        <view class="form-section__head">
          <text class="form-section__title">反馈类型</text>
          <text class="form-section__copy">先把问题归类，再补描述和截图，方便后端与产品快速定位。</text>
          <view class="form-summary-row">
            <text wx:for="{{summaryPills}}" wx:key="label" class="form-summary-pill {{item.active ? 'form-summary-pill--primary' : ''}}">{{item.label}}</text>
          </view>
        </view>

        <view class="option-grid">
          <view wx:for="{{feedbackTypeOptions}}" wx:key="value" class="option-chip {{form.feedbackType === item.value ? 'option-chip--active' : ''}}" data-value="{{item.value}}" bindtap="onPickOption">{{item.label}}</view>
        </view>
        <text wx:if="{{fieldErrors.feedbackType}}" class="form-field__error">{{fieldErrors.feedbackType}}</text>
      </view>

      <view class="surface-card form-section">
        <view class="form-section__head">
          <text class="form-section__title">问题描述</text>
          <text class="form-section__copy">请尽量写明出现位置、预期结果和实际现象。</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">问题描述</text><text class="form-field__required">必填</text></view>
          <textarea class="form-textarea {{fieldErrors.content ? 'form-textarea--error' : ''}}" placeholder="最多 300 字" maxlength="300" auto-height="{{true}}" value="{{form.content}}" data-field="content" bindinput="onFieldInput"></textarea>
          <text wx:if="{{fieldErrors.content}}" class="form-field__error">{{fieldErrors.content}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">问题截图</text></view>
          <uploader-grid files="{{form.screenshots}}" maxCount="4" helperText="选填，最多 4 张；截图越清晰，越有助于快速定位问题。" bind:change="onScreenshotChange"></uploader-grid>
          <text wx:if="{{fieldErrors.screenshots}}" class="form-field__error">{{fieldErrors.screenshots}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">联系方式</text></view>
          <input class="form-input {{fieldErrors.contact ? 'form-input--error' : ''}}" placeholder="选填，最多 40 字" maxlength="40" value="{{form.contact}}" data-field="contact" bindinput="onFieldInput" />
          <text wx:if="{{fieldErrors.contact}}" class="form-field__error">{{fieldErrors.contact}}</text>
        </view>
      </view>
    </block>
  </view>

  <bottom-action-bar primaryText="{{submitted ? '返回上一页' : '提交反馈'}}" secondaryText="重置表单" primaryDisabled="{{primaryDisabled}}" loading="{{submitting}}" bottomInset="{{bottomInset}}" bind:primary="onPrimaryAction" bind:secondary="onSecondaryAction"></bottom-action-bar>
</view>
