<view class="page-shell page-shell--tight-bottom">
  <app-hero-header
    theme="surface"
    kicker="举报记录"
    title="查看处理进展"
    subtitle="每条举报都会保留对象、原因、状态与处理结论摘要。"
    showBack="{{true}}"
    topInset="{{topInset}}"
  ></app-hero-header>

  <view class="surface-card insight-card motion-slide-up">
    <view class="insight-card__head">
      <view>
        <text class="insight-card__eyebrow">处理进度</text>
        <text class="insight-card__title">这里优先回答“平台有没有接收、现在走到哪一步、是否已经有处理结论”。</text>
      </view>
      <text class="pill-primary">{{activeTab === 'all' ? '全部记录' : '当前筛选'}}</text>
    </view>
    <view class="guide-grid">
      <view class="guide-card">
        <text class="guide-card__eyebrow">阅读顺序</text>
        <text class="guide-card__title">先看最近一条，再切状态筛选</text>
        <text class="guide-card__copy">最近记录会优先告诉你当前对象、原因和平台处理摘要，便于快速判断是否还需要补充材料。</text>
      </view>
    </view>
  </view>

  <view class="page-stack records-stack">
    <page-skeleton wx:if="{{pageState === 'loading'}}"></page-skeleton>
    <page-error-state
      wx:elif="{{pageState === 'error'}}"
      title="举报记录暂时没加载出来"
      description="{{errorText}}"
      actionText="重新加载"
      bind:action="loadPage"
    ></page-error-state>
    <empty-state
      wx:elif="{{pageState === 'empty'}}"
      title="还没有举报记录"
      description="提交举报后，处理进展会在这里持续更新；当前先保留统一的状态浏览入口。"
      actionText="去提交举报"
      bind:action="onEmptyAction"
    ></empty-state>
    <block wx:else>
      <view wx:if="{{latestRecord}}" class="surface-card latest-card">
        <text class="latest-card__title">最近一条举报</text>
        <text class="latest-card__headline">{{latestRecord.targetTypeLabel}} · {{latestRecord.reasonLabel}}</text>
        <text class="latest-card__copy">状态：{{latestRecord.status}}</text>
        <text class="latest-card__copy">处理摘要：{{latestRecord.resultAction || '平台已接收举报并进入处理队列'}}</text>
        <text class="latest-card__copy">{{latestRecord.nextActionText}}</text>
      </view>

      <stats-summary-card items="{{stats}}"></stats-summary-card>

      <view class="segment-row">
        <view wx:for="{{tabs}}" wx:key="value" class="segment {{activeTab === item.value ? 'segment--active' : ''}}" data-value="{{item.value}}" bindtap="onSwitchTab">{{item.label}}</view>
      </view>

      <view wx:if="{{filteredEmpty}}" class="surface-card inline-empty-card">
        <text class="inline-empty-card__title">当前筛选下暂无记录</text>
        <text class="inline-empty-card__copy">上面的统计和状态筛选会继续保留，方便你快速切回其它状态查看，不需要整页返回。</text>
      </view>

      <block wx:else>
        <view wx:for="{{list}}" wx:key="reportId" class="surface-card record-card">
          <view class="record-card__head">
            <text class="record-card__title">{{item.targetTypeLabel}}</text>
            <text class="record-card__status record-card__status--{{item.statusBucket}}">{{item.status}}</text>
          </view>
          <view class="record-card__chips">
            <text class="record-card__chip">{{item.reasonLabel}}</text>
            <text wx:if="{{item.targetId}}" class="record-card__chip">对象 {{item.targetId}}</text>
          </view>
          <text class="record-card__copy">处理摘要：{{item.resultAction || '平台已收到举报，正在排队处理。'}}</text>
          <text class="record-card__copy">{{item.nextActionText}}</text>
        </view>
      </block>
    </block>
  </view>
</view>
