.manage-stack {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.manage-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.manage-item,
.manage-detail-card,
.manage-contact-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.manage-item--active {
  box-shadow: 0 24rpx 60rpx rgba(47, 107, 255, 0.14);
}

.manage-item__head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.manage-item__meta,
.manage-detail-card__copy,
.manage-item__copy,
.manage-contact-card__copy,
.manage-detail-card__empty {
  font-size: 26rpx;
  line-height: 1.6;
  color: #5c6980;
}

.manage-item__title,
.manage-detail-card__title,
.manage-contact-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #152033;
}

.manage-item__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.manage-item__chip,
.manage-item__contact,
.manage-action-grid__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.manage-item__chip {
  border: 1px solid rgba(214, 224, 238, 0.92);
  background: rgba(255, 255, 255, 0.78);
  color: #152033;
}

.manage-item__contact {
  align-self: flex-start;
  background: rgba(214, 224, 238, 0.36);
  color: #5c6980;
}

.manage-item__contact--visible {
  background: rgba(18, 179, 168, 0.12);
  color: #0a766f;
}

.manage-action-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.manage-action-grid__button {
  min-width: 200rpx;
  border: 1px solid rgba(47, 107, 255, 0.24);
  background: linear-gradient(180deg, rgba(47, 107, 255, 0.12), rgba(255, 255, 255, 0.92));
  color: #2457e6;
}