<view class="page-shell">
  <app-hero-header
    theme="surface"
    kicker="编辑通告"
    title="修改并重新提交"
    subtitle="保留当前通告内容，修完后直接回提审流程。"
    showBack="{{true}}"
    topInset="{{topInset}}"
  ></app-hero-header>

  <view class="page-stack edit-stack">
    <page-skeleton wx:if="{{pageState === 'loading'}}"></page-skeleton>
    <page-error-state
      wx:elif="{{pageState === 'error'}}"
      title="编辑页暂时没打开"
      description="{{errorText}}"
      actionText="重新加载"
      bind:action="loadPage"
    ></page-error-state>
    <block wx:else>
      <view class="surface-card info-card">
        <text class="info-card__title">当前状态：{{currentStatusText}}</text>
        <text class="info-card__copy">{{infoCopy}}</text>
        <view class="form-summary-row">
          <text wx:for="{{summaryPills}}" wx:key="label" class="form-summary-pill {{item.active ? 'form-summary-pill--primary' : ''}}">{{item.label}}</text>
        </view>
      </view>

      <view class="surface-card insight-card motion-slide-up">
        <view class="insight-card__head">
          <view>
            <text class="insight-card__eyebrow">编辑路径</text>
            <text class="insight-card__title">编辑页先帮你判断是“补信息重新提审”，还是“先存修改稍后再确认”。</text>
          </view>
          <text class="pill-primary">{{currentStatusText}}</text>
        </view>
        <view class="guide-grid">
          <view class="guide-card">
            <text class="guide-card__eyebrow">本轮重点</text>
            <text class="guide-card__title">优先修影响审核判断的字段</text>
            <text class="guide-card__copy">标题、平台、领域、预算、截止时间和达人要求会直接影响再次审核时的可读性，建议优先确认。</text>
          </view>
          <view class="guide-card">
            <text class="guide-card__eyebrow">动作区别</text>
            <text class="guide-card__title">保存修改不会立刻对外生效</text>
            <text class="guide-card__copy">只有重新提交审核通过后，广场和详情页才会看到新的内容。</text>
          </view>
        </view>
      </view>

      <view class="surface-card form-section">
        <view class="form-section__head">
          <text class="form-section__title">通告核心信息</text>
          <text class="form-section__copy">修改不会直接生效，重新提交审核通过后才会回到广场展示。</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row">
            <text class="form-field__label">通告标题</text>
            <text class="form-field__required">必填</text>
          </view>
          <input class="form-input {{noticeErrors.title ? 'form-input--error' : ''}}" placeholder="最多 28 字" maxlength="28" value="{{noticeForm.title}}" data-field="title" bindinput="onNoticeInput" />
          <text wx:if="{{noticeErrors.title}}" class="form-field__error">{{noticeErrors.title}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">品牌或门店名称</text></view>
          <input class="form-input {{noticeErrors.brandName ? 'form-input--error' : ''}}" placeholder="选填，最多 20 字" maxlength="20" value="{{noticeForm.brandName}}" data-field="brandName" bindinput="onNoticeInput" />
          <text wx:if="{{noticeErrors.brandName}}" class="form-field__error">{{noticeErrors.brandName}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">合作平台</text><text class="form-field__required">必填</text></view>
          <view class="option-grid">
            <view wx:for="{{platformOptions}}" wx:key="value" class="option-chip {{noticeForm.cooperationPlatform === item.value ? 'option-chip--active' : ''}}" data-field="cooperationPlatform" data-value="{{item.value}}" bindtap="onPickNoticeOption">{{item.label}}</view>
          </view>
          <text wx:if="{{noticeErrors.cooperationPlatform}}" class="form-field__error">{{noticeErrors.cooperationPlatform}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">合作领域</text><text class="form-field__required">必填</text></view>
          <view class="option-grid">
            <view wx:for="{{categoryOptions}}" wx:key="value" class="option-chip {{noticeForm.cooperationCategory === item.value ? 'option-chip--active' : ''}}" data-field="cooperationCategory" data-value="{{item.value}}" bindtap="onPickNoticeOption">{{item.label}}</view>
          </view>
          <text wx:if="{{noticeErrors.cooperationCategory}}" class="form-field__error">{{noticeErrors.cooperationCategory}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">合作形式</text><text class="form-field__required">必填</text></view>
          <view class="option-grid">
            <view wx:for="{{cooperationTypeOptions}}" wx:key="value" class="option-chip {{noticeForm.cooperationType === item.value ? 'option-chip--active' : ''}}" data-field="cooperationType" data-value="{{item.value}}" bindtap="onPickNoticeOption">{{item.label}}</view>
          </view>
          <text wx:if="{{noticeErrors.cooperationType}}" class="form-field__error">{{noticeErrors.cooperationType}}</text>
        </view>
      </view>

      <view class="surface-card form-section">
        <view class="form-section__head">
          <text class="form-section__title">合作方式与预算</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">城市</text><text class="form-field__required">必填</text></view>
          <input class="form-input {{noticeErrors.city ? 'form-input--error' : ''}}" placeholder="例如：杭州" value="{{noticeForm.city}}" data-field="city" bindinput="onNoticeInput" />
          <text wx:if="{{noticeErrors.city}}" class="form-field__error">{{noticeErrors.city}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">结算方式</text><text class="form-field__required">必填</text></view>
          <view class="option-grid">
            <view wx:for="{{settlementTypeOptions}}" wx:key="value" class="option-chip {{noticeForm.settlementType === item.value ? 'option-chip--active' : ''}}" data-field="settlementType" data-value="{{item.value}}" bindtap="onPickNoticeOption">{{item.label}}</view>
          </view>
          <text wx:if="{{noticeErrors.settlementType}}" class="form-field__error">{{noticeErrors.settlementType}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">预算区间</text><text class="form-field__required">必填</text></view>
          <block wx:if="{{noticeForm.settlementType === 'barter' || noticeForm.settlementType === 'free_experience'}}">
            <view class="form-picker"><text>当前结算方式下不适用</text><text class="form-picker__arrow">—</text></view>
          </block>
          <view wx:else class="option-grid">
            <view wx:for="{{budgetRangeOptions}}" wx:key="value" class="option-chip {{noticeForm.budgetRange === item.value ? 'option-chip--active' : ''}}" data-field="budgetRange" data-value="{{item.value}}" bindtap="onPickNoticeOption">{{item.label}}</view>
          </view>
          <text wx:if="{{noticeErrors.budgetRange}}" class="form-field__error">{{noticeErrors.budgetRange}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">招募人数</text></view>
          <input class="form-input {{noticeErrors.recruitCount ? 'form-input--error' : ''}}" type="number" placeholder="选填，例如 6" value="{{noticeForm.recruitCount}}" data-field="recruitCount" bindinput="onNoticeInput" />
          <text wx:if="{{noticeErrors.recruitCount}}" class="form-field__error">{{noticeErrors.recruitCount}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">报名截止日期</text><text class="form-field__required">必填</text></view>
          <picker mode="date" value="{{noticeForm.deadlineAt}}" bindchange="onDeadlineChange">
            <view class="form-picker {{noticeErrors.deadlineAt ? 'form-picker--error' : ''}}">
              <text class="{{noticeForm.deadlineAt ? '' : 'form-picker__placeholder'}}">{{noticeForm.deadlineAt || '请选择日期'}}</text>
              <text class="form-picker__arrow">›</text>
            </view>
          </picker>
          <text wx:if="{{noticeErrors.deadlineAt}}" class="form-field__error">{{noticeErrors.deadlineAt}}</text>
        </view>
      </view>

      <view class="surface-card form-section">
        <view class="form-section__head"><text class="form-section__title">达人要求与合作说明</text></view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">达人要求</text><text class="form-field__required">必填</text></view>
          <textarea class="form-textarea {{noticeErrors.creatorRequirements ? 'form-textarea--error' : ''}}" placeholder="最多 200 字" maxlength="200" auto-height="{{true}}" value="{{noticeForm.creatorRequirements}}" data-field="creatorRequirements" bindinput="onNoticeInput"></textarea>
          <text wx:if="{{noticeErrors.creatorRequirements}}" class="form-field__error">{{noticeErrors.creatorRequirements}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">合作说明</text><text class="form-field__required">必填</text></view>
          <textarea class="form-textarea {{noticeErrors.cooperationDescription ? 'form-textarea--error' : ''}}" placeholder="最多 500 字" maxlength="500" auto-height="{{true}}" value="{{noticeForm.cooperationDescription}}" data-field="cooperationDescription" bindinput="onNoticeInput"></textarea>
          <text wx:if="{{noticeErrors.cooperationDescription}}" class="form-field__error">{{noticeErrors.cooperationDescription}}</text>
        </view>

        <view class="form-field">
          <view class="form-field__label-row"><text class="form-field__label">补充图片</text></view>
          <uploader-grid files="{{noticeForm.attachments}}" maxCount="6" helperText="最多 6 张；修改后会跟随草稿一起保存。" bind:change="onAttachmentsChange"></uploader-grid>
          <text wx:if="{{noticeErrors.attachments}}" class="form-field__error">{{noticeErrors.attachments}}</text>
        </view>
      </view>
    </block>
  </view>

  <bottom-action-bar primaryText="重新提交审核" secondaryText="{{savingDraft ? '保存中...' : '保存修改'}}" helperText="{{savingDraft ? '正在保存当前修改' : '保存修改不会直接改线上展示，确认无误后再重新提交审核'}}" primaryDisabled="{{primaryDisabled}}" loading="{{primaryLoading}}" bottomInset="{{bottomInset}}" bind:primary="onPrimaryAction" bind:secondary="onSecondaryAction"></bottom-action-bar>
</view>
