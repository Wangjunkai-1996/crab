<view class="page-shell page-shell--tight-bottom">
  <app-hero-header theme="surface" kicker="我的通告" title="管理已发布通告" subtitle="按状态查看，快速找到待处理或正在进行的合作需求。" showBack="{{true}}" topInset="{{topInset}}"></app-hero-header>
  <view class="surface-card insight-card motion-slide-up">
    <view class="insight-card__head">
      <view>
        <text class="insight-card__eyebrow">通告管理</text>
        <text class="insight-card__title">列表先帮你判断“该去看详情、去编辑，还是直接进报名管理”。</text>
      </view>
      <text class="pill-primary">{{activeStatus === 'all' ? '全部通告' : '当前筛选'}}</text>
    </view>
    <view class="guide-grid">
      <view class="guide-card">
        <text class="guide-card__eyebrow">卡片结构</text>
        <text class="guide-card__title">状态、预算、报名量和下一步动作在同一屏</text>
        <text class="guide-card__copy">这样发布方在列表里就能快速判断，是继续推进合作，还是先回编辑页补信息。</text>
      </view>
    </view>
    <view wx:if="{{focusNotice}}" class="focus-card">
      <view class="focus-card__head">
        <text class="focus-card__title">当前优先处理</text>
        <text class="pill-accent">{{focusNotice.badgeText}}</text>
      </view>
      <text class="focus-card__headline">{{focusNotice.title}}</text>
      <text class="focus-card__copy">{{focusNotice.copy}}</text>
    </view>
  </view>
  <view class="list-stack">
    <page-skeleton wx:if="{{pageState === 'loading'}}"></page-skeleton>
    <page-error-state wx:elif="{{pageState === 'error'}}" title="通告列表加载失败" description="{{errorText}}" actionText="重新加载" bind:action="loadPage"></page-error-state>
    <empty-state wx:elif="{{pageState === 'empty'}}" title="还没有通告记录" description="可以先回发布页继续创建合作需求，后续所有状态也会统一回到这里管理。" actionText="去发布通告" bind:action="onEmptyAction"></empty-state>
    <block wx:else>
      <stats-summary-card items="{{stats}}"></stats-summary-card>
      <view class="segment-row">
        <view wx:for="{{tabs}}" wx:key="value" class="segment {{activeStatus === item.value ? 'segment--active' : ''}}" data-value="{{item.value}}" bindtap="onSwitchStatus">{{item.label}}</view>
      </view>
      <view wx:if="{{filteredEmpty}}" class="surface-card inline-empty-card">
        <text class="inline-empty-card__title">当前状态下暂无通告</text>
        <text class="inline-empty-card__copy">保留上面的统计和筛选栏，方便你继续切换状态快速浏览，不用整页退回再选一次。</text>
      </view>
      <block wx:else>
        <view wx:for="{{notices}}" wx:key="noticeId" class="surface-card notice-manage-card">
          <view class="notice-manage-card__head">
            <status-tag status="{{item.statusTag}}" text="{{item.statusText}}"></status-tag>
            <text class="notice-manage-card__meta">{{item.createdAt}}</text>
          </view>
          <text class="notice-manage-card__title">{{item.title}}</text>
          <view class="notice-manage-card__metrics">
            <text class="notice-manage-card__pill notice-manage-card__pill--accent">{{item.budgetSummary}}</text>
            <text class="notice-manage-card__pill">报名 {{item.applicationCount || 0}}</text>
          </view>
          <text class="notice-manage-card__copy">{{item.actionHint}}</text>
          <view class="notice-manage-card__actions">
            <view class="notice-manage-card__button notice-manage-card__button--primary" data-id="{{item.noticeId}}" data-action="{{item.actionConfig.primaryAction}}" bindtap="onTapAction">{{item.actionConfig.primaryText}}</view>
            <view wx:if="{{item.actionConfig.secondaryText}}" class="notice-manage-card__button" data-id="{{item.noticeId}}" data-action="{{item.actionConfig.secondaryAction}}" bindtap="onTapAction">{{item.actionConfig.secondaryText}}</view>
            <view wx:if="{{item.actionConfig.dangerText}}" class="notice-manage-card__button notice-manage-card__button--danger" data-id="{{item.noticeId}}" data-action="{{item.actionConfig.dangerAction}}" bindtap="onTapAction">{{item.actionConfig.dangerText}}</view>
          </view>
        </view>
      </block>
    </block>
  </view>
</view>
