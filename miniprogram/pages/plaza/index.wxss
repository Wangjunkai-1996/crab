.plaza-stack {
  margin-top: 24rpx;
}

.search-box {
  padding: 0 24rpx;
  min-height: 88rpx;
  border-radius: 20rpx;
  border: 1px solid rgba(216, 226, 239, 0.96);
  background: linear-gradient(180deg, rgba(251, 253, 255, 0.98), rgba(244, 248, 253, 0.96));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.78), 0 10rpx 22rpx rgba(26, 48, 90, 0.04);
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.search-box--dark {
  padding: 0 24rpx;
  min-height: 88rpx;
  border-radius: 20rpx;
  border: 1px solid rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.14);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
}

.search-box__icon {
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  position: relative;
  color: rgba(255, 255, 255, 0.78);
}

.search-box__icon::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -10rpx;
  width: 10rpx;
  height: 4rpx;
  background: currentColor;
  transform: rotate(45deg);
  border-radius: 999rpx;
}

.search-box__text {
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

.ad-card {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.ad-card__badge,
.ad-card__tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.12);
  color: #2457e6;
  font-size: 24rpx;
}

.ad-card__title {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #152033;
}

.ad-card__copy {
  display: block;
  margin-top: 8rpx;
  color: #5c6980;
  font-size: 26rpx;
  line-height: 1.6;
}