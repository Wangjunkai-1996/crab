{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "ES2020"
    ],
    "typeRoots": [
      "./typings"
    ]
  },
  "include": [
    "./**/*.ts",
    "./**/*.d.ts"
  ]
}
